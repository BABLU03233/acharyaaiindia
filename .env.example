# ============================================================================
# ACHARYA AI - PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================
# 
# IMPORTANT: Never commit actual API keys to version control
# Use: .env.local (git-ignored) for development secrets
# Use: Environment variables in production hosting platform (Cloudflare, Vercel, etc.)
#
# ============================================================================

# CLAUDE AI - API CREDENTIALS
# Get your key at: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-your-actual-key-here

# ============================================================================
# SUPABASE - DATABASE & AUTHENTICATION
# ============================================================================

# From: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key (SERVER-SIDE ONLY - never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# STRIPE - PAYMENT PROCESSING
# ============================================================================

# Get your keys at: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_live_your-stripe-public-key
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Product & Price IDs (create these in Stripe Dashboard)
VITE_STRIPE_PREMIUM_MONTHLY_ID=price_xxxxxxxxxxxxxxxx
VITE_STRIPE_PREMIUM_MONTHLY_PRICE=9.99

VITE_STRIPE_PREMIUM_YEARLY_ID=price_yyyyyyyyyyyyyyyyy
VITE_STRIPE_PREMIUM_YEARLY_PRICE=99.99

VITE_STRIPE_ONE_TIME_ID=price_zzzzzzzzzzzzzzzz
VITE_STRIPE_ONE_TIME_PRICE=4.99

# ============================================================================
# RAZORPAY - PAYMENT PROCESSING (INDIA)
# ============================================================================
# Get your keys at: https://dashboard.razorpay.com/#/app/keys

RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ============================================================================
# EMAIL NOTIFICATIONS
# ============================================================================

# SendGrid for transactional emails
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@acharya-ai.com

# ============================================================================
# ANALYTICS & MONITORING
# ============================================================================

# Sentry for error tracking (https://sentry.io)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/xxxxx

# PostHog for product analytics (https://posthog.com)
POSTHOG_API_KEY=phc_your-posthog-key

# ============================================================================
# DEPLOYMENT
# ============================================================================

# Application environment
NODE_ENV=production

# Application URLs
VITE_APP_URL=https://acharya-ai.com
VITE_APP_NAME=Acharya AI

# ============================================================================
# SECURITY
# ============================================================================

# JWT Secret for API authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://acharya-ai.com,https://www.acharya-ai.com

# ============================================================================
# ADVANCED OPTIONS
# ============================================================================

# Enable debug logging
DEBUG=false

# Rate limiting settings (requests per minute)
RATE_LIMIT_READS=100
RATE_LIMIT_WRITES=30

# File upload settings
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
